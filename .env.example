# MySQL (docker-compose defaults)
DATABASE_URL="mysql://dsb:dsb@localhost:3306/dsb_law"

# Shared Prisma pool size (web container; production default 20 in docker-compose.prod.yml)
# DATABASE_POOL_SIZE=20

# Auth.js / NextAuth v5
AUTH_SECRET="replace-with-openssl-rand-hex-32"
AUTH_TRUST_HOST="true"

# Public site URL (sitemap, emails, share links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed admin (npm run db:seed)
SEED_ADMIN_EMAIL="admin@gmail.com"
SEED_ADMIN_PASSWORD="Admin@12345"

# Redis + newsletters
REDIS_URL="redis://localhost:6379"

# ── Email — dummy DSB Law Group domain (change when you buy a real domain) ───
#
# Dummy domain used in this project:  dsblawgroup.com
# Dummy addresses:
#   Send from:  noreply@dsblawgroup.com
#   Reply to:   info@dsblawgroup.com
#
# Local dev: leave RESEND_API_KEY empty → emails log to the terminal.
# Production: sign up at https://resend.com, verify dsblawgroup.com (or your
# real domain), then paste your API key below.
#
RESEND_API_KEY=""
RESEND_FROM_DOMAIN="dsblawgroup.com"
EMAIL_FROM_NAME="DSB Law Group"
EMAIL_FROM_ADDRESS="noreply"
EMAIL_FROM="DSB Law Group <noreply@dsblawgroup.com>"
EMAIL_REPLY_TO="info@dsblawgroup.com"

# Production site URL (use on VPS — not localhost)
# NEXT_PUBLIC_SITE_URL="https://www.dsblawgroup.com"

# Production Docker (docker-compose.prod.yml)
# Use KEY=VALUE lines only (not YAML "KEY: value"). Example:
# MYSQL_ROOT_PASSWORD=change-me
# MYSQL_PASSWORD=change-me
# AUTH_SECRET=your-secret
# NEXT_PUBLIC_SITE_URL=https://www.dsblawgroup.com
#
# Do NOT put docker-compose lines like "DATABASE_URL: mysql://..." in .env.
# DATABASE_URL for containers is set in docker-compose.prod.yml from MYSQL_PASSWORD.

# Dev cache junction is not supported with Turbopack (breaks Tailwind/PostCSS).
# For faster dev, clone the project to C:\Dev\pervinder-nextjs instead.
